{
  "name": "[module_template_name]",
  "context": ".",
  "protocol": "sftp",

  "defaultProfile": "[server_profile]",

  "profiles": {

    "server_sftp": {
      "host": "[server_ip]",
      "protocol": "sftp",
      "port": 22,
      "username": "[server_user]",
      "password": "[server_password]",
      "interactiveAuth": false,
      "remotePath": "[remote_path]"
    },

    "server_ssh": {
      "host": "[server_ip]",
      "protocol": "sftp",
      "port": 22,
      "username": "[ssh_user]",
      "agent": "ssh-agent",
      "sshConfigPath": "~/.ssh/config",
      "privateKeyPath": "~/.ssh/id_rsa",
      "passphrase": "[password_ssh_file]",
      "interactiveAuth": false,
      "remotePath": "[remote_path]"
    }

  },

  "ignore": [
    ".atl",
    ".claude",
    "AGENTS.md",
    "CLAUDE.md",
    "CLAUDE.*.md",

    ".ddev",

    ".git",
    ".github",
    ".gitlab",
    ".gitlab-ci.yml",
    ".gitattributes",

    ".vscode",
    ".wakatime-project",
    ".well-known",
    "node_modules",
    "debug.log",

    "phpcs.xml",
    "phpdox.xml",
    "phpmd.xml",
    "phpunit.xml",
    "phpstan.neon",

    ".env",
    "env.properties*",

    ".playwright-cli",
    ".playwright-mcp",
    "/tests/playwright/_report",
    "/tests/playwright/_results",

    "/drush/contrib/",
    "/vendor/",
    "/private_files/",
    "/web/core/",
    "/web/modules/contrib/",
    "/web/modules/custom/*/vendor",
    "/web/themes/contrib/",
    "/web/profiles/contrib/",
    "/web/libraries/",
    "/web/sites/*/files/",
    "/web/sites/simpletest",

    "/web/sites/*/settings.php",
    "/web/sites/*/settings.*.php"
  ],

  "connectTimeout": 10000,
  "uploadOnSave": true,
  "downloadOnOpen": false,
  "syncOption": {
    "delete": true,
    "update": true
  },
  "watcher": {
    "files": "**/*",
    "autoUpload": true,
    "autoDelete": true
  },
  "concurrency": 4
}
