{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "XDebug [DDEV]",
      "type": "php",
      "request": "launch",
      "port": 9003,
      "log": false,
      "stopOnEntry": false,
      "xdebugSettings": {
        "max_children": 128,
        "max_data": 1024,
        "max_depth": 3,
        "show_hidden": 1
      },
      "pathMappings": {
        "/var/www/html": "${workspaceFolder}/",
      },
      "preLaunchTask": "hidden: ddev xdebug on",
      "postDebugTask": "hidden: ddev xdebug off"
    },
    {
      "name": "PhpUnit dummy",
      "type": "php",
      "request": "launch",
      "port": 9001,
    }
  ],
  "compounds": [
    {
        "name": "PhpUnit",
        "configurations": ["XDebug [DDEV]", "PhpUnit dummy"]
    }
  ]
}
